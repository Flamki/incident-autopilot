# -----------------------------
# Frontend (Vite)
# -----------------------------
VITE_API_BASE_URL="http://localhost:8000"
VITE_WS_BASE_URL="ws://localhost:8000"

# -----------------------------
# Backend (FastAPI)
# -----------------------------
ENVIRONMENT="development"
DEV_AUTH_BYPASS="false"
LOG_LEVEL="INFO"
API_PORT="8000"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,https://incident-autopilot-three.vercel.app"

# GitLab OAuth
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""
GITLAB_REDIRECT_URI="http://localhost:8000/auth/gitlab/callback"
# Optional GitLab PAT fallback (lets repo connect/agents run without GitLab login flow)
GITLAB_ACCESS_TOKEN=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:8000/auth/github/callback"

# Frontend URL for OAuth callbacks
# In production, set this to your deployed frontend URL (for example: https://incident-autopilot-three.vercel.app)
FRONTEND_APP_URL="http://localhost:3000"

# Public backend base URL (used for creating GitLab webhooks)
PUBLIC_API_BASE_URL="http://localhost:8000"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret-32-chars-min"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_DAYS="7"

# Database (optional in this starter - current runtime uses in-memory dev store)
DATABASE_URL=""

# Optional token encryption key (Fernet)
ENCRYPTION_KEY=""

# Optional notifications
SLACK_WEBHOOK_URL=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Optional callback secret between agents and API
AGENT_CALLBACK_SECRET=""

# Agent runtime mode:
# - gitlab_duo (recommended): wait for GitLab Duo Agent Platform callbacks (no Anthropic API key required)
# - local: run in-app Python agents using Anthropic API key (or fallback mode without key)
AGENT_RUNTIME_MODE="gitlab_duo"

# Anthropic / Claude runtime
# Not needed when AGENT_RUNTIME_MODE=gitlab_duo
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
ANTHROPIC_API_BASE="https://api.anthropic.com/v1/messages"
