# -----------------------------
# Frontend (Vite)
# -----------------------------
VITE_API_BASE_URL="http://localhost:8000"
VITE_WS_BASE_URL="ws://localhost:8000"

# -----------------------------
# Backend (FastAPI)
# -----------------------------
ENVIRONMENT="development"
LOG_LEVEL="INFO"
API_PORT="8000"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,https://incident-autopilot-three.vercel.app"

# GitLab OAuth
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""
GITLAB_REDIRECT_URI="http://localhost:8000/auth/gitlab/callback"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret-32-chars-min"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_DAYS="7"

# Database (optional in this starter - current runtime uses in-memory dev store)
DATABASE_URL=""

# Optional token encryption key (Fernet)
ENCRYPTION_KEY=""

# Optional notifications
SLACK_WEBHOOK_URL=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Optional callback secret between agents and API
AGENT_CALLBACK_SECRET=""